---
import { SITE } from '../../config/site.config';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    transparent
      ? 'bg-transparent border-transparent'
      : 'border-b border-border-subtle backdrop-blur-md bg-bg-primary/80',
  ]}
>
  <nav class="max-w-7xl mx-auto px-8 h-16 flex items-center justify-between">
    <a
      href={SITE.nav.links[0].href}
      class:list={[
        'text-lg font-bold transition-opacity hover:opacity-80',
        transparent ? 'text-white' : 'gradient-text',
      ]}
    >
      {SITE.title}
    </a>

    <ul class="flex items-center gap-1">
      {SITE.nav.links.map((link) => {
        const isActive = currentPath === link.href ||
          (link.href !== SITE.nav.links[0].href && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={link.href}
              class:list={[
                'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                isActive
                  ? 'text-text-primary bg-white/[0.12]'
                  : transparent
                    ? 'text-white/80 hover:text-white hover:bg-white/[0.1]'
                    : 'text-text-secondary hover:text-text-primary hover:bg-white/[0.05]',
              ]}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <a
      href={`${SITE.nav.links[0].href}search`}
      aria-label="Search"
      class:list={[
        'p-2 rounded-lg transition-all duration-200',
        transparent
          ? 'text-white/80 hover:text-white hover:bg-white/[0.1]'
          : 'text-text-secondary hover:text-text-primary hover:bg-white/[0.05]',
      ]}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
    </a>
  </nav>
</header>
