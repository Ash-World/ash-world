---
import { SITE } from '../../config/site.config';
import { getCollection } from 'astro:content';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isSearchPage = currentPath.endsWith('/search') || currentPath.endsWith('/search/');

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5);

const base = SITE.nav.links[0].href;

const iconClass = [
  'p-2 rounded-lg transition-all duration-200',
  transparent
    ? 'text-white/80 hover:text-white hover:bg-white/10'
    : 'text-text-secondary hover:text-text-primary hover:bg-white/[0.05]',
].join(' ');
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    transparent ? 'bg-transparent' : 'border-b border-border-subtle backdrop-blur-md bg-bg-primary/80',
  ]}
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- 좌: 그리드 메뉴 아이콘 -->
    <button
      id="menu-toggle"
      aria-label="메뉴 열기"
      aria-expanded="false"
      class={iconClass}
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
        <circle cx="5"  cy="5"  r="2" />
        <circle cx="13" cy="5"  r="2" />
        <circle cx="5"  cy="13" r="2" />
        <circle cx="13" cy="13" r="2" />
      </svg>
    </button>

    <!-- 우: 검색 토글 + 최신활동 -->
    <div class="flex items-center gap-1">

      <!-- 검색: 검색 페이지면 뒤로, 아니면 검색으로 -->
      <a
        href={isSearchPage ? base : `${base}search`}
        aria-label={isSearchPage ? '이전 페이지로' : '검색'}
        class={iconClass}
      >
        {isSearchPage ? (
          <!-- X 아이콘 (검색 페이지에서 닫기) -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12" />
          </svg>
        ) : (
          <!-- 돋보기 아이콘 -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
        )}
      </a>

      <!-- 최신활동: 아이콘 + 최근 5개 포스트 리스트 -->
      {recentPosts.length > 0 && (
        <div class="relative group">
          <!-- 속이 뚫린 흰 원형 아이콘 (클릭 액션 없음) -->
          <div
            role="img"
            aria-label="최신 활동"
            class="relative w-9 h-9 rounded-full cursor-default flex items-center justify-center
              transition-all duration-200 hover:bg-white/10"
          >
            <!-- amber dot -->
            <span class="absolute top-[6px] right-[6px] w-2 h-2 rounded-full bg-accent-amber border border-bg-primary z-10" />
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"
              class:list={[transparent ? 'text-white/80' : 'text-text-secondary']}>
              <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.8" />
            </svg>
          </div>

          <!--
            hover gap 방지: top-9(아이콘 높이)로 붙이고 pt-3으로 시각적 간격 확보.
            패딩 내부는 여전히 group 영역이므로 hover가 끊기지 않음.
          -->
          <div class="absolute top-9 right-0 w-64 z-50 pt-3
            opacity-0 pointer-events-none translate-y-0.5
            group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0
            transition-all duration-200 ease-out">
            <!-- 말풍선 꼭지 -->
            <div class="absolute top-[6px] right-4 w-3 h-3 bg-bg-secondary border-t border-l border-border-subtle rotate-45 z-10" />
            <div class="bg-bg-secondary backdrop-blur-md border border-border-subtle rounded-2xl overflow-hidden shadow-xl shadow-black/50">
              <!-- 헤더 -->
              <div class="px-4 pt-3 pb-2 border-b border-border-subtle">
                <p class="text-text-muted text-[10px] uppercase tracking-widest font-medium">최신 포스트</p>
              </div>
              <!-- 포스트 리스트 (최대 5개, 클릭 시 이동) -->
              {recentPosts.map((post) => (
                <a
                  href={`${base}posts/${post.slug}`}
                  class="flex items-baseline justify-between gap-3 px-4 py-3
                    border-b border-border-subtle last:border-b-0
                    hover:bg-white/[0.05] transition-colors duration-150 group/item"
                >
                  <p class="text-text-primary text-sm font-medium truncate
                    group-hover/item:text-accent-amber transition-colors duration-150">
                    {post.data.title}
                  </p>
                  <time class="text-text-muted text-xs shrink-0">
                    {post.data.publishDate.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}
                  </time>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</header>

<!-- 메뉴 오버레이 배경 -->
<div
  id="menu-backdrop"
  class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
/>

<!-- 슬라이드인 메뉴 패널 -->
<nav
  id="menu-panel"
  aria-label="사이트 내비게이션"
  class="fixed top-0 left-0 bottom-0 z-50 w-72 bg-bg-secondary border-r border-border-subtle
    -translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
    flex flex-col"
>
  <div class="flex items-center justify-between px-6 h-16 border-b border-border-subtle shrink-0">
    <span class="text-lg font-bold gradient-text">{SITE.title}</span>
    <button
      id="menu-close"
      aria-label="메뉴 닫기"
      class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-white/[0.05] transition-all duration-200"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>
  </div>

  <ul class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    {SITE.nav.links.map((link) => {
      const isActive = currentPath === link.href ||
        (link.href !== SITE.nav.links[0].href && currentPath.startsWith(link.href));
      return (
        <li>
          <a
            href={link.href}
            class:list={[
              'flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all duration-200',
              isActive
                ? 'text-accent-amber bg-accent-amber/10 border border-accent-amber/20'
                : 'text-text-secondary hover:text-text-primary hover:bg-white/[0.05]',
            ]}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>

  <div class="px-6 py-5 border-t border-border-subtle shrink-0">
    <a
      href={SITE.about.links[0].href}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 text-text-muted hover:text-text-secondary text-sm transition-colors duration-200"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
      </svg>
      GitHub
    </a>
  </div>
</nav>

<script>
  // View Transitions 사용 시 페이지 이동마다 재실행 필요
  function initMenu() {
    const toggle   = document.getElementById('menu-toggle');
    const close    = document.getElementById('menu-close');
    const panel    = document.getElementById('menu-panel');
    const backdrop = document.getElementById('menu-backdrop');

    if (!toggle || !close || !panel || !backdrop) return;

    function openMenu() {
      panel.classList.remove('-translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      panel.classList.add('-translate-x-full');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);
    close.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    }, { once: true });
  }

  // 초기 로드 + View Transitions 이후 페이지 이동 시 모두 실행
  document.addEventListener('astro:page-load', initMenu);
</script>
