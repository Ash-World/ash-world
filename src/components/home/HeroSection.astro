---
import { SITE } from '../../config/site.config';
import CategoryTags from './CategoryTags.astro';
import { getCollection } from 'astro:content';

const { hero } = SITE;

const posts = await getCollection('posts', ({ data }) => !data.draft);
const latestPost = posts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
)[0];
const base = SITE.nav.links[0].href;
---

<section class="relative w-full h-screen min-h-[600px] overflow-hidden">

  <!-- 배경 이미지 or CSS 그라데이션 -->
  {hero.backgroundImage ? (
    <div
      class="absolute inset-0 bg-cover bg-no-repeat"
      style={`background-image: url('${hero.backgroundImage}'); background-position: ${'backgroundPosition' in hero ? hero.backgroundPosition : 'center center'};`}
    />
  ) : (
    <div class="absolute inset-0 hero-gradient" />
  )}

  <!-- 오버레이 레이어 -->
  <!-- 좌측: 텍스트 가독성 (이미지 좌측이 이미 어두우므로 약하게) -->
  <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/20 to-transparent" />
  <!-- 상단: 헤더 네비 가독성 -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/10 to-transparent" />
  <!-- 하단: 페이지 본문과 자연스럽게 연결 -->
  <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/40 to-transparent" />

  <!-- 상단 중앙: 알림 배지 (헤더 아래 적절한 간격) -->
  <div class="absolute top-20 left-1/2 -translate-x-1/2 z-10 whitespace-nowrap">
    <div class="flex items-center gap-3 bg-black/30 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-amber animate-pulse shrink-0" />
      <span class="text-white/70 text-xs">PR로 포스트를 기여할 수 있어요</span>
      <a
        href="https://github.com/ash-hun/ash-world"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs font-semibold text-bg-primary bg-accent-amber hover:bg-accent-warm px-3 py-1 rounded-full transition-colors duration-200 shrink-0"
      >
        GitHub →
      </a>
    </div>
  </div>

  <!-- 메인 콘텐츠: 뷰포트 40~70% 구간에 위치 -->
  <div class="absolute inset-0 z-10 flex flex-col justify-center pt-[8%] px-8 sm:px-12">
    <div class="flex items-end justify-between gap-8 max-w-7xl mx-auto w-full">

      <!-- 좌측: 텍스트 + 카테고리 태그 -->
      <div class="flex-1 min-w-0">
        <p class="text-white/60 text-base sm:text-lg mb-1 font-light">{hero.greeting}</p>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold mb-3 leading-[1.05]">
          <span class="text-white drop-shadow-lg">{hero.name}</span>
        </h1>
        <p class="text-white/55 text-base sm:text-lg mb-8 font-light">{hero.subtitle}</p>
        <CategoryTags />
      </div>

      <!-- 우측: Quick Links 카드 -->
      {latestPost && (
        <div class="hidden lg:block w-60 shrink-0 self-end mb-4">
          <a
            href={`${base}posts/${latestPost.slug}`}
            class="block group rounded-2xl overflow-hidden bg-black/30 backdrop-blur-md border border-white/10 p-5
              hover:bg-black/40 hover:border-white/20 transition-all duration-300"
          >
            <p class="text-white/40 text-[10px] uppercase tracking-widest mb-2 font-medium">
              {SITE.home.practiceToolsTitle}
            </p>
            <h3 class="text-white text-sm font-semibold leading-snug mb-2
              group-hover:text-accent-amber transition-colors duration-200 line-clamp-2">
              {latestPost.data.title}
            </h3>
            <p class="text-white/50 text-xs line-clamp-2 mb-3 leading-relaxed">
              {latestPost.data.description}
            </p>
            <div class="flex flex-wrap gap-1">
              {latestPost.data.tags.slice(0, 2).map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-white/10 text-white/60 border border-white/10">
                  #{tag}
                </span>
              ))}
            </div>
          </a>
        </div>
      )}
    </div>
  </div>

</section>
