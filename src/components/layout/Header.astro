---
import { SITE } from '../../config/site.config';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border-subtle backdrop-blur-md bg-bg-primary/80">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={SITE.nav.links[0].href} class="text-lg font-bold gradient-text hover:opacity-80 transition-opacity">
      {SITE.title}
    </a>

    <ul class="flex items-center gap-1">
      {SITE.nav.links.map((link) => (
        <li>
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200
              ${currentPath === link.href || (link.href !== SITE.nav.links[0].href && currentPath.startsWith(link.href))
                ? 'text-text-primary bg-white/[0.08]'
                : 'text-text-secondary hover:text-text-primary hover:bg-white/[0.05]'
              }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href={`${SITE.nav.links[0].href}search`}
      aria-label="Search"
      class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-white/[0.05] transition-all duration-200"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
    </a>
  </nav>
</header>

<div class="h-16" />
