---
import { SITE } from '../../config/site.config';
---

<footer class="border-t border-border-subtle mt-24">
  <div class="max-w-screen-2xl mx-auto px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-text-muted text-sm">{SITE.footer.copyright}</p>

    <div class="flex items-center gap-4">
      {SITE.about.links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-text-secondary text-sm transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
