---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostCard from '../../components/post/PostCard.astro';
import TagPill from '../../components/common/TagPill.astro';
import { SITE } from '../../config/site.config';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

// 태그 빈도 집계
const tagCounts = sortedPosts
  .flatMap((p) => p.data.tags)
  .reduce<Record<string, number>>((acc, tag) => {
    acc[tag] = (acc[tag] ?? 0) + 1;
    return acc;
  }, {});

const base = SITE.nav.links[0].href;
---

<BaseLayout title="Posts" description="모든 포스트 목록">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-text-primary mb-2">Posts</h1>
      <p class="text-text-secondary">총 {sortedPosts.length}개의 글</p>
    </div>

    <div class="flex gap-10">
      <!-- 포스트 목록 -->
      <div class="flex-1">
        {sortedPosts.length === 0 ? (
          <div class="glass-card p-12 text-center">
            <p class="text-text-muted">아직 작성된 포스트가 없습니다.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {sortedPosts.map((post) => (
              <PostCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                publishDate={post.data.publishDate}
                tags={post.data.tags}
                cover={post.data.cover}
              />
            ))}
          </div>
        )}
      </div>

      <!-- 태그 사이드바 -->
      <aside class="hidden lg:block w-56 shrink-0">
        <div class="glass-card p-5 sticky top-24">
          <h3 class="text-sm font-semibold text-text-secondary uppercase tracking-wider mb-4">Tags</h3>
          <div class="flex flex-wrap gap-2">
            {Object.entries(tagCounts)
              .sort((a, b) => b[1] - a[1])
              .map(([tag, count]) => (
                <TagPill tag={tag} href={`${base}tags/${tag}`} count={count} />
              ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
